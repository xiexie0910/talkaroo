# Gemini (Vertex AI + Application Default Credentials)
GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
# GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
# GEMINI_COACH_MODEL=gemini-2.5-flash-lite
# Coach HTTP timeout per attempt (ms). Default 25000.
# COACH_TIMEOUT_MS=25000
# Silence before end-of-speech (ms). Vertex Live allows 0–2000. Default 900.
# Raise toward 1500–2000 if the partner cuts you off mid-thought.
# GEMINI_LIVE_SILENCE_MS=900

# Supabase (Auth + Postgres)
NEXT_PUBLIC_SUPABASE_URL=
# Prefer the publishable key; anon key still works
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
