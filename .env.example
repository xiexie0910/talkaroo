# Supabase (Auth + Postgres) — required
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Vertex AI — required
GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1

# Vercel / production: service account (pick ONE style)
# Prefer GOOGLE_SERVICE_ACCOUNT_JSON = entire key JSON as one line
# (private_key inside JSON may keep literal \n — that is fine).
# GOOGLE_SERVICE_ACCOUNT_JSON=
#
# Or split fields. For GOOGLE_PRIVATE_KEY on Vercel, paste with literal \n
# (one line), NOT real line breaks — or use GOOGLE_PRIVATE_KEY_BASE64.
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_PRIVATE_KEY_BASE64=

# Optional model / VAD tuning
# GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
# GEMINI_COACH_MODEL=gemini-2.5-flash-lite
# COACH_TIMEOUT_MS=25000
# GEMINI_LIVE_SILENCE_MS=900
# GEMINI_LIVE_PREFIX_PADDING_MS=160
# GEMINI_LIVE_START_SENSITIVITY=low
